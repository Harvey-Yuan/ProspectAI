# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised redirect URI: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Session ───────────────────────────────────────────────────────────────────
# Any long random string — used to sign the session cookie
SESSION_SECRET=replace-with-a-long-random-secret

# ── OpenAI (used by Master / Browser / CRM agents) ───────────────────────────
OPENAI_API_KEY=sk-...

# ── InsForge LLM (OpenAI-compatible, used by all agents) ─────────────────────
# Base URL: your InsForge project's AI endpoint
INSFORGE_BASE_URL=https://uw7kmade.us-east.insforge.app/ai/v1
# Anon key: generate with `get-anon-key` MCP tool (never expires)
INSFORGE_ANON_KEY=your-anon-key-here
